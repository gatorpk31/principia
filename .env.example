# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# ── Supabase (optional — cloud progress sync for premium users) ──────────────
# Get from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── RevenueCat (required for in-app purchases) ───────────────────────────────
# Get from: https://app.revenuecat.com → Project → API Keys
REVENUECAT_APPLE_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
REVENUECAT_GOOGLE_KEY=goog_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── EAS (set after running `eas init`) ───────────────────────────────────────
# Paste the UUID shown after running: npx eas-cli init
EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
