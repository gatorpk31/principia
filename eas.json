{
  "cli": {
    "version": ">= 16.0.0",
    "promptToInstallDependencies": "always"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "env": {
        "SUPABASE_URL": "PLACEHOLDER",
        "SUPABASE_ANON_KEY": "PLACEHOLDER",
        "REVENUECAT_APPLE_KEY": "PLACEHOLDER",
        "REVENUECAT_GOOGLE_KEY": "PLACEHOLDER"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "YOUR_APPLE_ID_EMAIL",
        "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "YOUR_APPLE_TEAM_ID"
      }
    }
  }
}
